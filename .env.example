# =============================================================================
# FINANCE CALCULATOR — Environment Variables Template
# =============================================================================
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in the real values in .env
#   3. NEVER commit .env to git
# =============================================================================

# --- Application ---
# ENV: "development" | "staging" | "production"
# DEBUG: true only in development (shows stack traces to users — dangerous in prod)
APP_NAME="Finance Calculator"
APP_VERSION="0.1.0"
ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# --- Server ---
# HOST: 0.0.0.0 means "listen on all network interfaces" (needed in Docker)
# PORT: FastAPI's default
HOST=0.0.0.0
PORT=8000
WORKERS=1

# --- Database (PostgreSQL) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
# asyncpg: async driver (faster than psycopg2 for async code)
# localhost:5432 when running locally
# postgres:5432 when running in Docker Compose (service name = hostname)
DATABASE_URL=postgresql+asyncpg://finance_user:finance_password@localhost:5432/finance_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# --- Redis ---
# Used for: JWT token blacklist, rate limiting, caching, Celery broker
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# --- JWT Authentication ---
# ALGORITHM: HS256 = HMAC-SHA256 (symmetric key — same key signs and verifies)
# ACCESS_TOKEN_EXPIRE_MINUTES: Short (15-60 min) for security
# REFRESH_TOKEN_EXPIRE_DAYS: Long (7-30 days) for convenience
JWT_SECRET_KEY=your-jwt-secret-key-must-be-different-from-app-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS (Cross-Origin Resource Sharing) ---
# Which domains can call our API from a browser
# "*" = any domain (fine for dev, dangerous in prod)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# --- Email (SMTP) ---
# For password reset emails, notification emails
# In dev: use Mailtrap (catches emails, doesn't send them)
# In prod: use AWS SES or SendGrid
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@finance-calculator.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=true
MAIL_SSL=false

# --- AWS (Production only) ---
# In dev, these are not needed
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=finance-calculator-files
AWS_S3_ENDPOINT_URL=

# --- Celery (Background Tasks) ---
# Uses Redis as the message broker
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Logging ---
# LOG_LEVEL: DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_FORMAT: "json" for production (parseable by CloudWatch), "console" for dev
LOG_LEVEL=DEBUG
LOG_FORMAT=console

# --- Rate Limiting ---
# Protect against brute force and DDoS
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# --- Feature Flags ---
# Toggle features without redeploying
ENABLE_REGISTRATION=true
ENABLE_EMAIL_VERIFICATION=false
ENABLE_AI_SUGGESTIONS=false
